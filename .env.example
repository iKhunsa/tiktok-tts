# TikTok TTS — Variables de entorno opcionales
# Copia este archivo a .env y completa los valores necesarios

# ── Casterlabs (multi-plataforma con un clic) ────────────────────────────────
# Referencia: https://github.com/Casterlabs/caffeinated
# Estado: pendiente de investigación sobre disponibilidad de API pública
CASTERLABS_CLIENT_ID=
CASTERLABS_CLIENT_SECRET=

# ── Kick.com ─────────────────────────────────────────────────────────────────
# Nota: Kick usa Cloudflare que bloquea requests desde Node.js (403)
# Requiere BrowserWindow permanente o solución alternativa
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=

# ── Twitch OAuth (opcional — sin esto funciona en modo anónimo) ───────────────
# Crea tu app en: https://dev.twitch.tv/console/apps
# Redirect URI: http://localhost:3000/auth/twitch/callback
TWITCH_CLIENT_ID=
