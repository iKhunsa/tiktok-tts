{
  "name": "tiktok-live-tts",
  "version": "1.0.0",
  "description": "TikTok Live Chat TTS Reader",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node build.js"
  },
  "pkg": {
    "scripts": [
      "server.js",
      "tray.js"
    ],
    "assets": [
      "node_modules/systray/traybin/**/*",
      "node_modules/tiktok-live-connector/dist/proto/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^4.18.2",
    "google-tts-api": "^2.0.2",
    "multer": "^2.1.1",
    "systray": "^1.0.5",
    "tiktok-live-connector": "^1.2.3",
    "undici": "^8.0.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.19.0"
  }
}
