# Copia este archivo como .env y rellena los valores
# cp .env.example .env

# Token secreto para acceder al dashboard (cámbialo!)
ADMIN_TOKEN=pon_aqui_un_token_secreto

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=pon_aqui_una_password_segura

# Puerto donde escucha el dashboard (default 4000)
PORT=4000
